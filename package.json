    "@angular/material-date-fns-adapter": "20.2.14",
    "@angular/platform-browser": "20.3.9",
    "@angular/platform-browser-dynamic": "20.3.9",
    "@angular/router": "20.3.9",
    "@fontsource/open-sans": "^5.1.0",
    "@mat-datetimepicker/core": "16.0.1",
